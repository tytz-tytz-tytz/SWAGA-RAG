{
  "run": { "name": "wider_drill_soft_structure_mean", "append_timestamp": false, "out_dir": "artifacts/swaga_rag_results" },

  "drill": {
    "top_r": 5,
    "top_k": 3,
    "tau_local": 0.25,
    "tau_child": 0.30,
    "margin": 0.10
  },

  "expand": {
    "max_depth": 2,
    "max_nodes": 800,
    "allowed_relations": ["HAS_SUBSECTION", "HAS_CHUNK"]
  },

  "score": {
    "mode": "full",

    "w_text": 1.0,
    "w_type": 0.1,
    "w_level": 0.05,
    "w_dist": 0.05,

    "type_bonus": {
      "list_item": 1.0,
      "chunk": 0.6,
      "section_title": 0.8,
      "caption": 0.2
    },

    "level_bonus": {
      "1": 0.1,
      "2": 0.2,
      "3": 0.3
    },

    "aggregation": "mean"
  },

  "output": { "top_k_text": 20, "save_debug": false }
}
